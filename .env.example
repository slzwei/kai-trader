# Kai Trader - local environment
# Copy this file to .env and fill in real values. Never commit .env.

# Telegram
TELEGRAM_BOT_TOKEN=123456:replace-with-real-bot-token
TELEGRAM_OWNER_ID=000000000

# Supabase
SUPABASE_URL=https://your-project-ref.supabase.co
# Service role key (JWT starting with eyJ...). Get from Supabase dashboard > Settings > API.
# Not required for Phase 1 but reserved for later phases.
SUPABASE_KEY=service-role-key-placeholder
# Postgres password for the Supabase project. Used by migrations and runtime DB access.
SUPABASE_DB_PASSWORD=replace-with-db-password
# Optional full Postgres URL. Set this when the direct host db.<ref>.supabase.co
# is unreachable (IPv4-only networks), using the Session pooler connection
# string from the Supabase dashboard. Leave unset to use the direct host.
# DATABASE_URL=postgresql://postgres.<ref>:<password>@aws-1-<region>.pooler.supabase.com:5432/postgres

# Alpaca
# Generate keys at https://app.alpaca.markets/paper/dashboard/overview > API Keys.
# Paper keys start with PK; live keys start with AK.
#
# The legacy ALPACA_API_KEY / ALPACA_SECRET_KEY pair is used in paper mode
# when no _PAPER override is set. Optionally set ALPACA_API_KEY_PAPER and
# ALPACA_API_KEY_LIVE to keep both pairs configured simultaneously and
# toggle between them with ALPACA_PAPER.
#
# Live mode (ALPACA_PAPER=false) strictly requires ALPACA_API_KEY_LIVE +
# ALPACA_SECRET_KEY_LIVE. The paper key is NOT used as a fallback in live
# mode; sending paper credentials to the live endpoint just 401s, which
# is louder as a configuration error.
ALPACA_API_KEY=replace-with-alpaca-key
ALPACA_SECRET_KEY=replace-with-alpaca-secret
# Optional explicit paper-key override (lets you keep both pairs around):
# ALPACA_API_KEY_PAPER=PK...
# ALPACA_SECRET_KEY_PAPER=...
# Live-trading keys (required when ALPACA_PAPER=false):
# ALPACA_API_KEY_LIVE=AK...
# ALPACA_SECRET_KEY_LIVE=...
# Set false only when intentionally moving to live trading.
ALPACA_PAPER=true

# Anthropic (conversational chat handler)
# Sign up at https://console.anthropic.com/. Required for free-form chat;
# slash commands keep working without it.
ANTHROPIC_API_KEY=sk-ant-replace-me
# Optional: override the default chat model.
# CHAT_MODEL=claude-sonnet-4-6

# Read-only Postgres DSN for the chat tool layer's query_supabase tool.
# Authenticate as kai_chat_ro (created by scripts/create_chat_ro_role.py).
# Use the same Session pooler host as DATABASE_URL but with the RO password.
# DATABASE_URL_RO=postgresql://kai_chat_ro:<password>@aws-1-<region>.pooler.supabase.com:5432/postgres
KAI_CHAT_RO_PASSWORD=replace-with-strong-random-password

# Optional out-of-band liveness ping. Use a service like healthchecks.io:
# create a check with expected interval ~10 min and grace period ~30 min,
# paste the unique ping URL here. The bot pings after every successful
# strategy tick, so a hang or kill stops the pings and the service emails
# you. When unset, the heartbeat is a no-op.
# HEARTBEAT_URL=https://hc-ping.com/<uuid-from-healthchecks-io>

# Periodic account-snapshot writer cadence. Default 3600s (one hour),
# floored at 60s. Snapshots are skipped while the market is closed.
# ACCOUNT_SNAPSHOT_INTERVAL_SECONDS=3600

# Daily realized-P&L summary auto-posted to Telegram. Fires at the
# configured UTC time each day; default 23:55 (a few minutes before the
# UTC day boundary so "Today" reflects the day that's closing).
# DAILY_REPORT_UTC_TIME=23:55
# DAILY_REPORT_ENABLED=true

# Weekly equity-curve chart auto-posted to Telegram. Default fires
# Monday 00:00 UTC and renders a Unicode sparkline + start/end/min/max
# stats from account_snapshots over the trailing 7 days.
# WEEKLY_CHART_UTC_DAY=0
# WEEKLY_CHART_UTC_TIME=00:00
# WEEKLY_CHART_ENABLED=true

# App
ENV=dev
LOG_LEVEL=INFO
TIMEZONE=Asia/Singapore
