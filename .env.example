# Kai Trader - local environment
# Copy this file to .env and fill in real values. Never commit .env.

# Telegram
TELEGRAM_BOT_TOKEN=123456:replace-with-real-bot-token
TELEGRAM_OWNER_ID=000000000

# Supabase
SUPABASE_URL=https://your-project-ref.supabase.co
# Service role key (JWT starting with eyJ...). Get from Supabase dashboard > Settings > API.
# Not required for Phase 1 but reserved for later phases.
SUPABASE_KEY=service-role-key-placeholder
# Postgres password for the Supabase project. Used by migrations and runtime DB access.
SUPABASE_DB_PASSWORD=replace-with-db-password
# Optional full Postgres URL. Set this when the direct host db.<ref>.supabase.co
# is unreachable (IPv4-only networks), using the Session pooler connection
# string from the Supabase dashboard. Leave unset to use the direct host.
# DATABASE_URL=postgresql://postgres.<ref>:<password>@aws-1-<region>.pooler.supabase.com:5432/postgres

# Alpaca
# Generate keys at https://app.alpaca.markets/paper/dashboard/overview > API Keys.
# Paper keys start with PK; live keys start with AK.
ALPACA_API_KEY=replace-with-alpaca-key
ALPACA_SECRET_KEY=replace-with-alpaca-secret
# Set false only when intentionally moving to live trading.
ALPACA_PAPER=true

# Anthropic (conversational chat handler)
# Sign up at https://console.anthropic.com/. Required for free-form chat;
# slash commands keep working without it.
ANTHROPIC_API_KEY=sk-ant-replace-me
# Optional: override the default chat model.
# CHAT_MODEL=claude-sonnet-4-6

# Read-only Postgres DSN for the chat tool layer's query_supabase tool.
# Authenticate as kai_chat_ro (created by scripts/create_chat_ro_role.py).
# Use the same Session pooler host as DATABASE_URL but with the RO password.
# DATABASE_URL_RO=postgresql://kai_chat_ro:<password>@aws-1-<region>.pooler.supabase.com:5432/postgres
KAI_CHAT_RO_PASSWORD=replace-with-strong-random-password

# App
ENV=dev
LOG_LEVEL=INFO
TIMEZONE=Asia/Singapore
